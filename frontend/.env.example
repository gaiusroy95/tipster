# Local development — run BOTH servers:
#   cd backend && npm run start:dev   → http://localhost:3000
#   cd frontend && npm run dev        → http://localhost:5173
VITE_API_URL=/api
VITE_SPORTS_API_URL=http://localhost:3000
VITE_ENABLE_MSW=true

# Google sign-in uses server redirect flow by default (no frontend client id required).
# Optional: set both below to use Google's popup button instead (requires JavaScript origins in Google Cloud).
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# VITE_GOOGLE_USE_GSI=true

# ── Vercel production (Project → Settings → Environment Variables) ──
# VITE_API_URL=/api
# VITE_SPORTS_API_URL=https://tipster-wqhx.onrender.com
# VITE_ENABLE_MSW=false
#
# API proxy: frontend/vercel.json rewrites /api/* and /sports/* to Render.
# To change backend URL, edit vercel.json rewrites (or set BACKEND_URL if using api proxy).

# Vercel project settings: Root Directory `frontend`, Build `npm run build`, Output `dist`.

# Social OAuth (optional — only for GSI popup mode)
VITE_FACEBOOK_APP_ID=
VITE_APPLE_CLIENT_ID=
