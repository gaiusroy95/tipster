VITE_API_URL=/api
VITE_ENABLE_MSW=true

# Vercel: Root Directory `frontend`, Build `npm run build`, Output `dist`.
# `/api/*` is served by serverless mocks in `api/[...path].ts` (no backend required).
# VITE_ENABLE_MSW=true is only needed for local `npm run dev` (Vite middleware).

# Social OAuth client IDs (used when connecting to real providers; MSW mocks ignore these)
VITE_GOOGLE_CLIENT_ID=
VITE_FACEBOOK_APP_ID=
VITE_APPLE_CLIENT_ID=
