PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Overtime.io V2
OVERTIME_BASE_URL=https://api.overtime.io/overtime-v2
X_API_KEY=your-overtime-api-key
OVERTIME_NETWORK_ID=10

# Cache TTLs (seconds)
CACHE_TTL_SPORTS=86400
CACHE_TTL_MARKET_TYPES=86400
CACHE_TTL_MARKETS=120
CACHE_TTL_LIVE_MARKETS=60
CACHE_TTL_MARKET_DETAIL=60

# Polling intervals (seconds)
POLL_MARKETS_INTERVAL=60
POLL_LIVE_INTERVAL=30
