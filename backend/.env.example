# Environment variables declared in this file are NOT automatically loaded by Prisma CLI.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with a flag to load environment variables from .env files.

# Sports API (Overtime proxy)
PORT=3000
X_API_KEY=your-overtime-api-key

# PostgreSQL
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

# Google OAuth (sign-in / sign-up)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs (add both if you use either in the browser):
#   http://localhost:5173/auth/callback
#   http://127.0.0.1:5173/auth/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# SMTP (password reset + email verification)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=noreply@yourdomain.com
