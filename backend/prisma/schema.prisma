generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  username            String    @unique
  displayName         String
  avatarUrl           String?
  passwordHash        String?
  balance             Int       @default(1000000)
  rank                Int       @default(0)
  role                UserRole  @default(USER)
  isBanned            Boolean   @default(false)
  bannedAt            DateTime?
  banReason           String?
  authProviders       String[]  @default(["email"])
  primaryAuthProvider String    @default("email")
  emailVerifiedAt     DateTime?
  registrationIp      String?
  verifiedIp          String?
  country             String?
  signature           String?
  signatureLink       String?
  signatureMode       String?
  postCount           Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  settings                  UserSettings?
  adminAuditLogs            AdminAuditLog[]
  passwordResetTokens       PasswordResetToken[]
  emailVerificationTokens   EmailVerificationToken[]
  walletTransactions        WalletTransaction[]
  socialAccounts            SocialAccount[]
  bets                      Bet[]
  seasonParticipants        SeasonParticipant[]
  notifications             Notification[]
  achievements              UserAchievement[]
  dailyBetUsage             DailyBetUsage[]
  twoFactorTrustedDevices   TwoFactorTrustedDevice[]
  twoFactorPhoneCodes       TwoFactorPhoneCode[]
  forumPosts                ForumPost[]
  forumPostViews            ForumPostView[]
  forumViewRewards          ForumViewReward[]
  forumComments             ForumComment[]
  forumPollVotes            ForumPollVote[]

  @@index([email])
  @@index([username])
}

model UserSettings {
  userId                 String    @id
  emailNotifications     Boolean   @default(true)
  pushNotifications      Boolean   @default(false)
  showProfilePublic      Boolean   @default(true)
  twoFactorEnabled       Boolean   @default(false)
  twoFactorMethod        String?
  twoFactorSecret        String?
  twoFactorPendingSecret String?
  phoneNumber            String?
  phoneVerifiedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TwoFactorTrustedDevice {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  lastIp    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model TwoFactorPhoneCode {
  id          String    @id @default(cuid())
  userId      String
  phoneNumber String
  codeHash    String
  purpose     String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, expiresAt])
}

model SocialAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  email             String
  linkedAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model OAuthState {
  state       String   @id
  provider    String
  mode        String
  redirectUri String
  userId      String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model WalletTransaction {
  id           String   @id @default(cuid())
  userId       String
  betId        String?
  type         String
  amount       Int
  balanceAfter Int
  description  String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  bet  Bet? @relation(fields: [betId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([betId])
}

model ForumPost {
  id            String    @id @default(cuid())
  authorId      String
  title         String
  body          String
  slug          String    @unique
  status        String    @default("published")
  scheduledAt   DateTime?
  coverImageUrl String?
  categoryId    String?
  tags          String[]  @default([])
  viewCount     Int       @default(0)
  commentCount  Int       @default(0)
  publishedAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  author      User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category    ForumCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  views       ForumPostView[]
  comments    ForumComment[]
  attachments ForumAttachment[]
  poll        ForumPoll?

  @@index([authorId, publishedAt])
  @@index([authorId, status])
  @@index([publishedAt])
  @@index([status, scheduledAt])
  @@index([categoryId])
}

model ForumCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  posts ForumPost[]
}

model ForumComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    ForumPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  ForumComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies ForumComment[] @relation("CommentReplies")

  @@index([postId, createdAt])
  @@index([authorId])
  @@index([parentId])
}

model ForumAttachment {
  id        String @id @default(cuid())
  postId    String
  type      String
  url       String
  title     String?
  sortOrder Int    @default(0)

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model ForumPoll {
  id       String    @id @default(cuid())
  postId   String    @unique
  question String
  endsAt   DateTime?
  createdAt DateTime @default(now())

  post    ForumPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  options ForumPollOption[]
  votes   ForumPollVote[]
}

model ForumPollOption {
  id        String @id @default(cuid())
  pollId    String
  label     String
  voteCount Int    @default(0)
  sortOrder Int    @default(0)

  poll  ForumPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes ForumPollVote[]

  @@index([pollId])
}

model ForumPollVote {
  id        String   @id @default(cuid())
  pollId    String
  optionId  String
  userId    String
  createdAt DateTime @default(now())

  poll   ForumPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option ForumPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([optionId])
}

model ForumPostView {
  id        String   @id @default(cuid())
  postId    String
  viewerKey String
  userId    String?
  createdAt DateTime @default(now())

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([postId, viewerKey])
  @@index([postId])
  @@index([userId])
}

model ForumViewReward {
  id         String   @id @default(cuid())
  userId     String
  milestone  Int
  amount     Int
  paidAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, milestone])
  @@index([userId])
}

model Bet {
  id               String    @id @default(cuid())
  userId           String
  matchId          String
  marketType       String
  selectionId      String
  selectionLabel   String
  odds             Float
  stake            Int
  potentialReturn  Int
  betSize          String
  status           String    @default("active")
  profitLoss       Int?
  placedAt         DateTime  @default(now())
  settledAt        DateTime?
  homeTeamName     String
  awayTeamName     String
  leagueName       String?
  matchStartTime   DateTime?
  sportId          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletTransactions WalletTransaction[]

  @@index([userId, placedAt])
  @@index([userId, status])
  @@index([matchId])
  @@index([status, matchId])
}

model DailyBetUsage {
  userId String
  date   String
  count  Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, date])
}

model Season {
  id          String   @id @default(cuid())
  name        String
  description String
  startDate   DateTime
  endDate     DateTime
  status      String   @default("upcoming")
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prizes       PrizeTier[]
  participants SeasonParticipant[]

  @@index([isActive])
  @@index([status])
}

model PrizeTier {
  id          String  @id @default(cuid())
  seasonId    String
  rankFrom    Int
  rankTo      Int
  name        String
  description String
  imageUrl    String?

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId])
}

model SeasonParticipant {
  id         String   @id @default(cuid())
  userId     String
  seasonId   String
  points     Int      @default(0)
  roi        Float    @default(0)
  profitLoss Int      @default(0)
  winRate    Float    @default(0)
  totalBets  Int      @default(0)
  wins       Int      @default(0)
  losses     Int      @default(0)
  voids      Int      @default(0)
  rank       Int      @default(0)
  form       String[] @default([])
  updatedAt  DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@index([seasonId, points])
  @@index([seasonId, rank])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  data      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, read])
}

model UserAchievement {
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
  @@index([userId])
}

model CuratedLeague {
  id               String   @id @default(cuid())
  overtimeLeagueId Int      @unique
  name             String
  country          String
  sportId          String
  isEnabled        Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([sportId, isEnabled, sortOrder])
}

model MarketTypeConfig {
  id          String   @id @default(cuid())
  marketType  String   @unique
  label       String
  description String?
  isEnabled   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isEnabled, sortOrder])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  admin User @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, createdAt])
  @@index([entityType, createdAt])
}
